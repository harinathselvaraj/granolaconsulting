# Set in Vercel project env (granola-admin) or copy to .env.local for local dev.
# Refresh from AWS after CDK deploy:
#   aws cloudformation describe-stacks --stack-name HoneyGoldProvisioningControlStack \
#     --query "Stacks[0].Outputs[?OutputKey=='ProvisioningApiUrl'].OutputValue" --output text
VITE_ADMIN_API_BASE=https://YOUR_API_ID.execute-api.eu-west-1.amazonaws.com/v1
VITE_COGNITO_DOMAIN=https://honeygold-starter.auth.eu-west-1.amazoncognito.com
VITE_COGNITO_CLIENT_ID=YOUR_ADMIN_COGNITO_CLIENT_ID
VITE_COGNITO_REGION=eu-west-1
VITE_COGNITO_REDIRECT_URI=https://admin.granolaconsulting.com/
