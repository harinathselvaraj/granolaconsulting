{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/products/:slug", "destination": "/product" },
    { "source": "/blog/:slug", "destination": "/blog" }
  ],
  "redirects": [
    { "source": "/profile.html", "destination": "/about", "permanent": true },
    { "source": "/blog", "destination": "/blogs", "permanent": true },
    { "source": "/blogs.html", "destination": "/blogs", "permanent": true },
    { "source": "/blog.html", "destination": "/blogs", "permanent": true },
    { "source": "/service.html", "destination": "/services", "permanent": true },
    { "source": "/product.html", "destination": "/products", "permanent": true },
    { "source": "/products.html", "destination": "/products", "permanent": true },
    { "source": "/honeygold-signin.html", "destination": "https://app.granolaconsulting.com/sign-in", "permanent": true },
    { "source": "/honeygold-login.html", "destination": "https://app.granolaconsulting.com/login", "permanent": true },
    { "source": "/honeygold-onboard.html", "destination": "https://app.granolaconsulting.com/onboard", "permanent": true },
    { "source": "/honeygold-privacy.html", "destination": "https://app.granolaconsulting.com/privacy-policy", "permanent": true },
    { "source": "/honeygold-terms.html", "destination": "https://app.granolaconsulting.com/terms", "permanent": true },
    { "source": "/honeygold-sandbox.html", "destination": "https://app.granolaconsulting.com/sandbox", "permanent": true },
    { "source": "/honeygold-checkout-success.html", "destination": "https://app.granolaconsulting.com/checkout-success", "permanent": true },
    { "source": "/honeygold-enterprise-thanks.html", "destination": "https://app.granolaconsulting.com/enterprise-thanks", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/downloads/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
